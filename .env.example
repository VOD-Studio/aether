# Matrix 配置
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USERNAME=your_username
MATRIX_PASSWORD=your_password
MATRIX_DEVICE_ID=your_device_id # 可选，用于持久化设备，避免重复登录创建新设备
DEVICE_DISPLAY_NAME="派蒙"
STORE_PATH=./store # 可选，Matrix SDK 存储路径

# OpenAI API 配置
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 机器人配置 (可选)
# SYSTEM_PROMPT=你是一个有帮助的AI助手
# BOT_COMMAND_PREFIX=!   # 命令前缀，默认为 "!"，支持 !bot, !ping 等
# BOT_OWNERS=@alice:matrix.org,@bob:matrix.org  # Bot 所有者，用逗号分隔，拥有最高权限
# MAX_HISTORY=10
# DB_PATH=./data/aether.db  # 数据库文件路径

# 流式输出配置 (可选)
# STREAMING_ENABLED=true
# STREAMING_MIN_INTERVAL_MS=1000
# STREAMING_MIN_CHARS=50

# 日志配置 (可选)
# LOG_LEVEL=info

# Vision 配置 (可选)
# VISION_ENABLED=true
# VISION_MODEL=gpt-4o  # 可选，支持 Vision 的模型，默认使用 OPENAI_MODEL
# VISION_MAX_IMAGE_SIZE=1024  # 图片最大尺寸（像素）

# 代理配置 (可选)
# PROXY=http://127.0.0.1:7890  # HTTP 代理 URL，支持 http:// 和 socks5://

# MCP (Model Context Protocol) 配置 (可选)
# MCP_ENABLED=true
# MCP_BUILTIN_TOOLS_ENABLED=true

# Meme 梗图配置 (可选)
# TENOR_API_KEY=your_tenor_api_key  # Tenor GIF API Key，从 https://developers.google.com/tenor/guides/quickstart 获取
# MEME_ENABLED=true
# MEME_LIMIT=8  # 每次搜索返回的结果数量

# WebFetch 内置工具配置
# MCP_BUILTIN_WEB_FETCH_ENABLED=true
# MCP_BUILTIN_WEB_FETCH_MAX_LENGTH=10000  # 最大内容长度（字符）
# MCP_BUILTIN_WEB_FETCH_TIMEOUT=10         # HTTP 请求超时（秒）

# 外部 MCP 服务器配置（JSON 数组格式）
# 示例：连接文件系统 MCP 服务器
# MCP_EXTERNAL_SERVERS=[{"name":"filesystem","transport":"stdio","command":"mcp-server-filesystem","args":["--root","/home/user"],"enabled":true}]
# 示例：连接多个服务器（多行格式）
# MCP_EXTERNAL_SERVERS=[
#   {"name":"filesystem","transport":"stdio","command":"mcp-server-filesystem","args":["--root","/home/user"],"enabled":true},
#   {"name":"database","transport":"http","url":"http://localhost:3000/mcp","enabled":true}
# ]
